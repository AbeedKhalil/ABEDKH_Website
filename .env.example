PORT=3000
JWT_SECRET=change-me-to-at-least-32-random-bytes-for-real

# Comma-separated list of origins allowed to call the API.
# Leave empty for local dev (allows all). For production, set the
# Netlify origin(s) your frontend is served from.
# Example: CORS_ORIGINS=https://abedkh.com,https://www.abedkh.com
CORS_ORIGINS=

DB_PATH=Backend/data/portfolio.sqlite
UPLOADS_DIR=Backend/uploads
